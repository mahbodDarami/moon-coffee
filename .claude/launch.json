{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Moon Coffee Static",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "npx serve . --listen 3000"],
      "port": 3000
    },
    {
      "name": "Moon Coffee Next.js",
      "runtimeExecutable": "node",
      "runtimeArgs": ["moon-coffee-next/node_modules/next/dist/bin/next", "dev", "moon-coffee-next", "-p", "3001"],
      "port": 3001
    }
  ]
}
